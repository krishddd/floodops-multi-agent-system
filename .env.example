# === Google Cloud ===
GOOGLE_MAPS_API_KEY=your-maps-api-key
GOOGLE_CLIENT_ID=your-oauth-client-id
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# === LLM reasoning core (provider-agnostic) ===
# The system boots and demos with NO key set (deterministic mock fallbacks).
# Set ONE provider's key and select it via FLOODOPS_LLM_PROVIDER.
#   FLOODOPS_LLM_PROVIDER = anthropic | gemini | groq | openrouter | openai-compat | auto
#   auto = first provider whose key is set (in that order), else mock.
FLOODOPS_LLM_PROVIDER=auto

# Anthropic (Claude) — default model claude-opus-4-8
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_EFFORT=medium          # low | medium | high | xhigh | max

# Google Gemini (free tier: aistudio.google.com — no credit card)
GOOGLE_GENAI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash

# Groq (free tier: console.groq.com — LPU-fast open-weight models, great for
# the N-run ensemble-vote loops)
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (pay-as-you-go aggregator + rotating free models; one key, any model)
OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Any other /chat/completions-compatible endpoint (Ollama, vLLM, Together, …)
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_API_KEY=anything
# OPENAI_COMPAT_MODEL=llama3.2

# Core-3 reasoning tuning (optional)
# LLM_ENSEMBLE_RUNS=3
# LLM_REFLEXION_MAX_RETRIES=3
# LLM_CONFIDENCE_FLOOR=0.75

# === USGS ===
API_USGS_PAT=your-usgs-api-key

# === ESA Copernicus / Sentinel Hub ===
SENTINEL_HUB_CLIENT_ID=your-sh-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sh-client-secret

# === ECMWF CDS ===
ECMWF_CDS_TOKEN=your-cds-personal-access-token

# === Frontend (Vite) ===
VITE_GOOGLE_MAPS_API_KEY=your-maps-api-key
VITE_WS_URL=ws://localhost:8000/ws/flood
VITE_API_URL=http://localhost:8000/api/v1
