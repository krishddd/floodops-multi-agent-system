# === Google Cloud ===
GOOGLE_MAPS_API_KEY=your-maps-api-key
GOOGLE_CLIENT_ID=your-oauth-client-id
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# === LLM reasoning core (provider-agnostic) ===
# The system boots and demos with NO key set (deterministic mock fallbacks).
# Set ONE provider's key and select it via FLOODOPS_LLM_PROVIDER.
#   FLOODOPS_LLM_PROVIDER = anthropic | gemini | groq | github | openrouter | openai-compat | auto
#   auto = first provider whose key is set (in that order), else mock.
FLOODOPS_LLM_PROVIDER=auto

# v4 heterogeneous ensemble pool — extra providers that vote alongside the
# primary in _ensemble_vote (comma-separated, e.g. "groq,github").
# LLM_ENSEMBLE_PROVIDERS=groq
# 429-cooldown for free-tier providers (seconds).
# LLM_RATE_LIMIT_COOLDOWN_S=300

# Anthropic (Claude) — default model claude-opus-4-8
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_EFFORT=medium          # low | medium | high | xhigh | max

# Google Gemini (free tier: aistudio.google.com — no credit card)
GOOGLE_GENAI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash

# Groq (free tier: console.groq.com — LPU-fast open-weight models, great for
# the N-run ensemble-vote loops)
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (pay-as-you-go aggregator + rotating free models; one key, any model)
OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# GitHub Models (free with any GitHub PAT — demo/eval tier, strict RPM/TPD caps)
GITHUB_MODELS_TOKEN=your-github-pat
# GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# Any other /chat/completions-compatible endpoint (Ollama, vLLM, Together, …)
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_API_KEY=anything
# OPENAI_COMPAT_MODEL=llama3.2

# === v5 ===
# Google Flood Forecasting API (the operational Nature-2024 model; free,
# CC BY 4.0). Join the waitlist + enable "Flood Forecasting API" in a Google
# Cloud project: https://support.google.com/flood-hub/answer/16364306
# Either name works — FLOODS_API_KEY is the name Google's colab/docs use;
# GOOGLE_FLOOD_API_KEY is the legacy FloodOps name (it wins if both are set).
# Put the real key ONLY in .env (gitignored) — never here.
FLOODS_API_KEY=
GOOGLE_FLOOD_API_KEY=

# === v4 ops layer ===
# SQLite persistence path (empty = disabled; single-node/eval — production
# swaps to PostgreSQL via an async driver).
# FLOODOPS_DB_PATH=floodops.db
# API auth: when set, /api/v1/* needs X-API-Key and the WS upgrade ?api_key=…
# FLOODOPS_API_KEY=
# ReliefWeb approved appname (free registration: apidoc.reliefweb.int)
# RELIEFWEB_APPNAME=
# Demo basin (Bagmati): centre, bbox half-width (deg), effective catchment km²
# BASIN_CENTER_LAT=27.7
# BASIN_CENTER_LNG=85.3
# BASIN_BBOX_HALF_DEG=1.0
# BASIN_EFFECTIVE_AREA_KM2=585
# Runoff ensemble (uncalibrated defaults) + verification loop
# ENSEMBLE_SPREAD=0.20
# RUNOFF_RECESSION_K=0.3
# VERIFICATION_JOB_INTERVAL_S=3600
# VERIFICATION_MIN_SAMPLES=20

# Core-3 reasoning tuning (optional)
# LLM_ENSEMBLE_RUNS=3
# LLM_REFLEXION_MAX_RETRIES=3
# LLM_CONFIDENCE_FLOOR=0.75

# === USGS ===
API_USGS_PAT=your-usgs-api-key

# === ESA Copernicus / Sentinel Hub ===
SENTINEL_HUB_CLIENT_ID=your-sh-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sh-client-secret

# === ECMWF CDS ===
ECMWF_CDS_TOKEN=your-cds-personal-access-token

# === Frontend (Vite) ===
VITE_GOOGLE_MAPS_API_KEY=your-maps-api-key
VITE_WS_URL=ws://localhost:8000/ws/flood
VITE_API_URL=http://localhost:8000/api/v1
