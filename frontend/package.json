{
  "name": "floodops-frontend",
  "version": "0.3.0",
  "description": "FloodOps — 3D flood monitoring visualization",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "^9.1.0",
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/google-maps": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@googlemaps/js-api-loader": "^2.1.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "globals": "^15.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
